# Travelpayouts affiliate marker (public id, safe to expose client-side).
# Used to build the per-bridge "Prenota questi giorni" booking deep-links.
# Get it from your Travelpayouts dashboard.
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=

# Buttondown API key (server-only). Do not prefix with NEXT_PUBLIC_.
BUTTONDOWN_API_KEY=

# Public site origin, no trailing slash. Used for canonical URLs, sitemap and robots.
# Falls back to https://calcolaferie.it when unset.
NEXT_PUBLIC_BASE_URL=

# Footer legal contact — data controller / site manager name.
# Falls back to "Spatariu Rares" when unset.
NEXT_PUBLIC_GESTORE=

# Footer contact email (privacy/GDPR requests).
# Falls back to privacy@calcolaferie.it when unset.
NEXT_PUBLIC_EMAIL=

# VAT number (Partita IVA). Optional: the footer line only renders when this is set.
NEXT_PUBLIC_PIVA=
